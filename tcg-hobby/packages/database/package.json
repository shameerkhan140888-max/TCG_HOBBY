{
  "name": "@tcg-hobby/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "node ./scripts/prisma-run.mjs generate && tsc -p tsconfig.json",
    "db:generate": "node ./scripts/prisma-run.mjs generate",
    "db:migrate": "node ./scripts/prisma-run.mjs migrate deploy",
    "db:seed": "node ./scripts/prisma-run.mjs db seed",
    "db:status": "node ./scripts/db-status.mjs",
    "db:verify": "node ./scripts/db-verify.mjs",
    "lint": "node ./scripts/prisma-run.mjs validate && tsc -p tsconfig.json --noEmit",
    "test": "node ./scripts/prisma-run.mjs generate && vitest run && node ./scripts/prisma-run.mjs validate",
    "typecheck": "node ./scripts/prisma-run.mjs validate && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tcg-hobby/auth": "*",
    "@prisma/client": "^6.10.1"
  },
  "devDependencies": {
    "@tcg-hobby/config": "*",
    "prisma": "^6.10.1",
    "tsx": "^4.19.2",
    "vitest": "^3.2.4"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
