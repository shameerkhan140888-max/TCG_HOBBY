{
  "name": "@tcg-hobby/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "node ./scripts/prisma-generate.mjs && tsc -p tsconfig.json",
    "db:generate": "node ./scripts/prisma-generate.mjs",
    "db:seed": "prisma db seed",
    "lint": "prisma validate && tsc -p tsconfig.json --noEmit",
    "test": "node ./scripts/prisma-generate.mjs && vitest run && prisma validate",
    "typecheck": "prisma validate && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tcg-hobby/auth": "*",
    "@prisma/client": "^6.10.1"
  },
  "devDependencies": {
    "@tcg-hobby/config": "*",
    "prisma": "^6.10.1",
    "tsx": "^4.19.2",
    "vitest": "^3.2.4"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
