generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  STAFF
  ADMIN
}

enum ProductCondition {
  MINT
  NEAR_MINT
  LIGHTLY_PLAYED
  MODERATELY_PLAYED
  HEAVILY_PLAYED
  DAMAGED
  SEALED
}

enum CartStatus {
  ACTIVE
  ABANDONED
  CONVERTED
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  FULFILLING
  SHIPPED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  REQUIRES_PAYMENT
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELED
  REFUNDED
}

enum FulfilmentStatus {
  PENDING
  PICKING
  PACKED
  SHIPPED
  CANCELLED
}

enum PricingRuleType {
  MANUAL
  COST_PLUS_PERCENT
  FIXED_MARGIN
  SUPPLIER_COST
  PROMOTIONAL
  FUTURE_MARKET_FEED
}

enum PricingRuleScope {
  GLOBAL
  PRODUCT
  CATEGORY
  SUPPLIER
}

enum PriceStatus {
  ACTIVE
  MANUAL_OVERRIDE
  DISABLED
  FUTURE
}

enum BuylistStatus {
  DRAFT
  SUBMITTED
  RECEIVED
  UNDER_REVIEW
  APPROVED
  REJECTED
  PAID
}

enum ProductReleaseStatus {
  RELEASED
  PREORDER
  COMING_SOON
  ARCHIVED
}

enum ProductRecommendationType {
  RELATED
  ACCESSORY
  UPSELL
  CROSS_SELL
  MANUAL
}

enum NotificationPreference {
  ALL
  PREORDER
  RELEASE
}

enum NotificationType {
  PRICE_MOVEMENT
  UPCOMING_RELEASE
  WISHLIST_AVAILABILITY
  COLLECTION_UPDATES
  BUYLIST_UPDATES
}

enum MarketingSubscriberStatus {
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
  SUPPRESSED
}

enum MarketingCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
  FAILED
}

enum WatchlistSubjectType {
  PRODUCT
  RELEASE
  COLLECTION_ITEM
}

enum MarketTrend {
  UP
  DOWN
  FLAT
  VOLATILE
}

enum CollectionPrintVariant {
  REGULAR
  REVERSE_HOLO
  HOLO
  PROMO
  FIRST_EDITION
  FOIL
}

enum DeckVisibility {
  PRIVATE
  PUBLIC
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  role          UserRole   @default(CUSTOMER)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  addresses     Address[]
  cart          Cart?
  orders        Order[]
  accounts      Account[]
  sessions      Session[]
  wishlist      Wishlist?
  buylists      Buylist[]
  collection    Collection?
  decks         Deck[]
  notificationSubscriptions NotificationSubscription[]
  watchlist     WatchlistItem[]
  notificationPreferences NotificationCenterPreference[]
  collectionInsightSnapshot CollectionInsightSnapshot?
  marketingSubscribers MarketingSubscriber[]
  marketingCampaigns MarketingCampaign[]
}

model Address {
  id           String   @id @default(cuid())
  userId       String?
  fullName     String
  email        String
  line1        String
  line2        String?
  city         String
  region       String?
  postalCode   String
  country      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  shippingOrders Order[] @relation("ShippingAddress")

  @@index([userId, country])
  @@index([postalCode, city])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId, provider])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expires])
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String
  sortOrder   Int       @default(0)
  imageLabel  String
  products    Product[]
  pricingRules PricingRule[]
  releases    Release[]
}

model Supplier {
  id              String            @id @default(cuid())
  name            String
  slug            String            @unique
  contactName     String?
  email           String?
  phone           String?
  website         String?
  addressLine1    String?
  addressLine2    String?
  city            String?
  region          String?
  postalCode      String?
  country         String            @default("GB")
  preferred       Boolean           @default(false)
  internalNotes   String?
  active          Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  supplierProducts SupplierProduct[]
  pricingRules    PricingRule[]
}

model Product {
  id            String           @id @default(cuid())
  importId      String?          @unique
  sku           String           @unique
  barcode       String?          @unique
  slug          String           @unique
  name          String
  brand         String?
  game          String
  setName       String?
  productType   String?
  language      String?
  description   String
  longDescription String
  condition     ProductCondition @default(SEALED)
  priceMinor    Int
  rrpMinor      Int?
  salePriceMinor Int?
  saleStartsAt  DateTime?
  saleEndsAt    DateTime?
  vatRate       Int              @default(20)
  currency      String           @default("GBP")
  featured      Boolean          @default(false)
  homepagePriority Int?
  heroFeatured Boolean           @default(false)
  recommendationWeight Int       @default(0)
  isAccessory   Boolean          @default(false)
  isStaffPick   Boolean          @default(false)
  isBestSeller  Boolean          @default(false)
  isNewArrival  Boolean          @default(false)
  freeUkStandardShipping Boolean @default(false)
  shippingPromotionProductOnly Boolean @default(true)
  lifecycleState String          @default("DRAFT")
  published     Boolean          @default(true)
  hideWhenOutOfStock Boolean     @default(false)
  archivedAt    DateTime?
  searchText    String
  imageLabel    String
  releaseStatus ProductReleaseStatus @default(RELEASED)
  releaseDate   DateTime?
  expectedDispatchAt DateTime?
  expectedArrivalAt DateTime?
  allocationLimit Int?
  customerPurchaseLimit Int?
  supplierAllocation Int?
  lowAllocationThreshold Int?
  availabilityMessage String?
  preorderBadgeLabel String?
  comingSoonBadgeLabel String?
  categoryId    String
  category      Category         @relation(fields: [categoryId], references: [id])
  inventory     InventoryItem?
  images        ProductImage[]
  wishlistItems WishlistItem[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  supplierProducts SupplierProduct[]
  stockAdjustments StockAdjustment[]
  pricing      ProductPricing?
  buylistItems  BuylistItem[]
  collectionItems CollectionItem[]
  deckCards     DeckCard[]
  pricingRules  PricingRule[]
  releaseProducts ReleaseProduct[]
  notificationSubscriptions NotificationSubscription[]
  marketSnapshots MarketSnapshot[]
  watchlistItems WatchlistItem[]
  recommendationsFrom ProductRecommendation[] @relation("ProductRecommendationSource")
  recommendationsTo   ProductRecommendation[] @relation("ProductRecommendationTarget")
  importSourceType String?
  importSourceReference String?
  importedAt     DateTime?
  lastImportedAt DateTime?
  importValidationWarnings String?
  seoTitle      String?
  metaDescription String?
  canonicalUrl  String?
  ogImageUrl    String?
  noindex       Boolean          @default(false)
  importAudits   ProductImportAudit[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([importId])
  @@index([slug, published])
  @@index([categoryId, published])
  @@index([archivedAt, published])
  @@index([published, featured])
  @@index([published, featured, homepagePriority])
  @@index([published, recommendationWeight])
  @@index([published, isAccessory])
  @@index([published, isStaffPick])
  @@index([published, isBestSeller])
  @@index([published, isNewArrival])
  @@index([published, heroFeatured])
  @@index([lifecycleState, published])
  @@index([releaseStatus, releaseDate])
  @@index([published, releaseStatus])
  @@index([published, hideWhenOutOfStock])
  @@index([name])
  @@index([barcode])
  @@index([brand])
  @@index([productType])
  @@index([searchText])
}

model ProductRecommendation {
  id                   String                    @id @default(cuid())
  sourceProductId      String
  recommendedProductId String
  relationshipType     ProductRecommendationType @default(RELATED)
  priority             Int                       @default(100)
  active               Boolean                   @default(true)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  sourceProduct        Product                   @relation("ProductRecommendationSource", fields: [sourceProductId], references: [id], onDelete: Cascade)
  recommendedProduct   Product                   @relation("ProductRecommendationTarget", fields: [recommendedProductId], references: [id], onDelete: Cascade)

  @@unique([sourceProductId, recommendedProductId, relationshipType])
  @@index([sourceProductId, active, priority])
  @@index([recommendedProductId])
  @@index([relationshipType, active])
}

model ProductImportAudit {
  id             String   @id @default(cuid())
  productId      String?
  product        Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  importId       String?
  sourceType     String
  sourceReference String?
  lifecycleState String
  changedFields  Json
  previousValues Json?
  nextValues     Json?
  warnings       String?
  performedBy    String?
  createdAt      DateTime @default(now())

  @@index([productId, createdAt])
  @@index([importId])
  @@index([createdAt])
}

model ProductImage {
  id         String   @id @default(cuid())
  productId  String
  url        String
  altText    String
  imageType  String   @default("gallery")
  sortOrder  Int      @default(0)
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, isPrimary])
  @@index([productId, sortOrder])
}

model Release {
  id               String          @id @default(cuid())
  name             String
  slug             String          @unique
  brand            String
  game             String
  categoryId       String
  releaseDate      DateTime
  expectedDispatchAt DateTime?
  expectedArrivalAt DateTime?
  announcementText String?
  releaseNotes     String?
  visible          Boolean         @default(true)
  featuredOnHomepage Boolean        @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  category         Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products         ReleaseProduct[]
  watchlistItems   WatchlistItem[]

  @@index([releaseDate, visible])
  @@index([featuredOnHomepage, visible])
  @@index([categoryId, releaseDate])
  @@index([brand, releaseDate])
}

model ReleaseProduct {
  id                  String               @id @default(cuid())
  releaseId           String
  productId           String
  status              ProductReleaseStatus @default(COMING_SOON)
  releaseDate         DateTime?
  expectedDispatchAt  DateTime?
  expectedArrivalAt   DateTime?
  allocationLimit     Int?
  customerPurchaseLimit Int?
  supplierAllocation  Int?
  allocatedQuantity   Int                  @default(0)
  lowAllocationThreshold Int?
  availabilityMessage  String?
  preorderBadgeLabel   String?
  comingSoonBadgeLabel String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  release             Release              @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  product             Product              @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([releaseId, productId])
  @@index([productId, status])
  @@index([releaseId, status])
  @@index([releaseDate, status])
  @@index([releaseId, productId])
}

model NotificationSubscription {
  id            String                @id @default(cuid())
  userId        String
  productId     String
  preference    NotificationPreference @default(ALL)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  product       Product               @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId, createdAt])
  @@index([userId, preference])
}

model NotificationCenterPreference {
  id              String              @id @default(cuid())
  userId          String
  notificationType NotificationType
  subjectType     WatchlistSubjectType?
  subjectLabel    String?
  emailEnabled    Boolean             @default(true)
  pushEnabled     Boolean             @default(false)
  inAppEnabled    Boolean             @default(true)
  lastTriggeredAt DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationType, subjectType, subjectLabel])
  @@index([userId, notificationType])
  @@index([notificationType, emailEnabled])
}

model MarketingSubscriber {
  id                              String                    @id @default(cuid())
  email                           String                    @unique
  firstName                       String?
  marketingConsent                Boolean                   @default(false)
  marketingConsentAt              DateTime?
  consentSource                   String?
  privacyPolicyVersion            String?
  consentIpHash                   String?
  source                          String                    @default("storefront")
  lastUpdatedSource               String?
  status                          MarketingSubscriberStatus @default(ACTIVE)
  customerId                      String?
  unsubscribeToken                String                    @unique
  lastSignupAt                    DateTime                  @default(now())
  confirmationEmailSentAt         DateTime?
  confirmationEmailLastAttemptAt  DateTime?
  confirmationEmailError          String?
  lastEmailSentAt                 DateTime?
  bouncedAt                       DateTime?
  suppressedAt                    DateTime?
  unsubscribedAt                  DateTime?
  createdAt                       DateTime                  @default(now())
  updatedAt                       DateTime                  @updatedAt
  customer                        User?                     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  tags                            MarketingSubscriberTagAssignment[]

  @@index([status, marketingConsent])
  @@index([source, createdAt])
  @@index([lastSignupAt])
  @@index([customerId])
  @@index([unsubscribedAt])
}

model MarketingSubscriberTag {
  id          String                              @id @default(cuid())
  slug        String                              @unique
  label       String
  description String?
  createdAt   DateTime                            @default(now())
  updatedAt   DateTime                            @updatedAt
  subscribers MarketingSubscriberTagAssignment[]

  @@index([label])
}

model MarketingSubscriberTagAssignment {
  subscriberId String
  tagId        String
  createdAt    DateTime              @default(now())
  subscriber   MarketingSubscriber   @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  tag          MarketingSubscriberTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([subscriberId, tagId])
  @@index([tagId])
}

model MarketingCampaign {
  id                 String                  @id @default(cuid())
  name               String
  subject            String
  previewText        String?
  status             MarketingCampaignStatus @default(DRAFT)
  audienceDefinition Json
  createdById        String?
  scheduledAt        DateTime?
  sentAt             DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  createdBy          User?                   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([scheduledAt])
  @@index([createdById])
}

model MarketSnapshot {
  id                  String          @id @default(cuid())
  productId           String          @unique
  currentEstimateMinor Int
  yesterdayMinor      Int
  sevenDayMinor       Int
  thirtyDayMinor      Int
  trend               MarketTrend
  confidenceScore     Int
  lastUpdatedAt       DateTime
  source              String
  currency            String          @default("GBP")
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  product             Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  history             MarketPriceHistory[]
  watchlistItems      WatchlistItem[]

  @@index([trend, lastUpdatedAt])
  @@index([confidenceScore, lastUpdatedAt])
  @@index([source, lastUpdatedAt])
}

model MarketPriceHistory {
  id            String         @id @default(cuid())
  snapshotId    String
  label         String
  valueMinor    Int
  recordedAt    DateTime
  createdAt     DateTime       @default(now())
  snapshot      MarketSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId, recordedAt])
  @@index([label, recordedAt])
}

model WatchlistItem {
  id                 String              @id @default(cuid())
  userId             String
  subjectType        WatchlistSubjectType
  subjectKey         String
  productId          String?
  releaseId          String?
  collectionItemId   String?
  marketSnapshotId   String?
  notificationType   NotificationType    @default(PRICE_MOVEMENT)
  emailEnabled       Boolean             @default(true)
  pushEnabled        Boolean             @default(false)
  inAppEnabled       Boolean             @default(true)
  note               String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  product            Product?            @relation(fields: [productId], references: [id], onDelete: Cascade)
  release            Release?            @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  collectionItem     CollectionItem?     @relation(fields: [collectionItemId], references: [id], onDelete: Cascade)
  marketSnapshot     MarketSnapshot?     @relation(fields: [marketSnapshotId], references: [id], onDelete: SetNull)

  @@unique([userId, subjectType, subjectKey])
  @@index([userId, notificationType])
  @@index([productId, createdAt])
  @@index([releaseId, createdAt])
  @@index([collectionItemId, createdAt])
  @@index([marketSnapshotId, createdAt])
}

model Wishlist {
  id        String         @id @default(cuid())
  userId    String         @unique
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WishlistItem[]
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  productId  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, productId])
  @@index([productId, createdAt])
  @@index([wishlistId, createdAt])
}

model InventoryItem {
  id            String   @id @default(cuid())
  productId     String   @unique
  stockOnHand   Int      @default(0)
  reservedStock Int      @default(0)
  reorderPoint  Int      @default(0)
  reorderQuantity Int    @default(0)
  incomingQuantity Int   @default(0)
  locationCode  String   @default("MAIN")
  updatedAt     DateTime @updatedAt
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([stockOnHand])
  @@index([reservedStock])
  @@index([reorderPoint, locationCode])
  @@index([incomingQuantity])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  status    CartStatus @default(ACTIVE)
  currency  String     @default("GBP")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
}

model CartItem {
  id             String   @id @default(cuid())
  cartId         String
  productId      String
  productName    String
  productSlug    String
  quantity       Int
  unitPriceMinor Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  cart           Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
}

model Order {
  id                 String      @id @default(cuid())
  orderNumber        String      @unique
  userId             String?
  status             OrderStatus @default(DRAFT)
  paymentStatus      PaymentStatus @default(REQUIRES_PAYMENT)
  fulfilmentStatus   FulfilmentStatus @default(PENDING)
  paymentProvider    String?
  paymentIntentId    String?     @unique
  stripeCheckoutSessionId String? @unique
  stripeCheckoutUrl   String?
  subtotalMinor      Int
  shippingMinor      Int
  taxMinor           Int
  totalMinor         Int
  currency           String      @default("GBP")
  shippingMethodCode  String
  shippingMethodName  String
  shippingMethodAmountMinor Int   @default(0)
  shippingFullName   String
  shippingEmail      String
  shippingLine1      String
  shippingLine2      String?
  shippingCity       String
  shippingRegion     String?
  shippingPostalCode String
  shippingCountry    String
  shippingAddressId  String?
  reservationExpiresAt DateTime?
  paidAt             DateTime?
  fulfilledAt        DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  user               User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  shippingAddress    Address?    @relation("ShippingAddress", fields: [shippingAddressId], references: [id], onDelete: SetNull)
  items              OrderItem[]

  @@index([userId, status])
  @@index([status, createdAt])
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  productId      String
  productName    String
  productSlug    String
  quantity       Int
  unitPriceMinor Int
  totalMinor     Int
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model StockAdjustment {
  id            String   @id @default(cuid())
  productId     String
  delta        Int
  beforeStock  Int
  afterStock   Int
  reason       String
  performedBy  String?
  createdAt    DateTime @default(now())
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
  @@index([createdAt])
}

model SupplierProduct {
  id             String   @id @default(cuid())
  supplierId     String
  productId      String
  supplierSku    String
  supplierProductUrl String?
  costMinor      Int
  minimumOrderQuantity Int @default(1)
  packQuantity   Int?
  currency       String   @default("GBP")
  leadTimeDays   Int      @default(7)
  lastPriceUpdatedAt DateTime?
  preferred      Boolean  @default(true)
  active         Boolean  @default(true)
  supplier       Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([supplierId, supplierSku])
  @@index([productId, preferred])
  @@index([supplierId, active])
}

model PricingRule {
  id         String            @id @default(cuid())
  name       String
  ruleType   PricingRuleType
  ruleScope  PricingRuleScope  @default(GLOBAL)
  productId  String?
  categoryId String?
  supplierId String?
  currency   String            @default("GBP")
  priority   Int               @default(0)
  active     Boolean           @default(true)
  config     Json
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  product    Product?          @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category?         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  supplier   Supplier?         @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  pricing    ProductPricing[]

  @@index([active, priority])
  @@index([ruleScope, active])
  @@index([productId, active])
  @@index([categoryId, active])
  @@index([supplierId, active])
}

model ProductPricing {
  id                     String       @id @default(cuid())
  productId              String       @unique
  pricingRuleId          String?
  costMinor              Int
  retailMinor            Int
  buyMinor               Int
  marginMinor            Int
  markupPercent          Int
  profitMinor            Int
  minimumMarginPercent   Int          @default(0)
  maximumDiscountPercent Int          @default(0)
  priceSource            String
  priceStatus            PriceStatus  @default(ACTIVE)
  manualOverride         Boolean      @default(false)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  product                Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  pricingRule            PricingRule? @relation(fields: [pricingRuleId], references: [id], onDelete: SetNull)

  @@index([buyMinor])
  @@index([priceSource, manualOverride])
  @@index([updatedAt])
}

model Buylist {
  id                   String         @id @default(cuid())
  buylistNumber        String         @unique
  userId               String
  status               BuylistStatus  @default(DRAFT)
  currency             String         @default("GBP")
  estimatedPayoutMinor Int            @default(0)
  offeredPayoutMinor   Int            @default(0)
  customerNotes        String?
  staffNotes           String?
  paymentReference     String?
  submittedAt          DateTime?
  receivedAt           DateTime?
  reviewedAt           DateTime?
  approvedAt           DateTime?
  rejectedAt           DateTime?
  paidAt               DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items                BuylistItem[]

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([createdAt])
}

model BuylistItem {
  id                String   @id @default(cuid())
  buylistId         String
  productId         String
  quantity          Int
  estimatedBuyMinor Int
  offeredBuyMinor   Int      @default(0)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  buylist           Buylist  @relation(fields: [buylistId], references: [id], onDelete: Cascade)
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([buylistId, productId])
  @@index([productId, createdAt])
}

model Collection {
  id            String          @id @default(cuid())
  userId        String          @unique
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         CollectionItem[]
  insightSnapshot CollectionInsightSnapshot?

  @@index([userId, createdAt])
}

model CollectionInsightSnapshot {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  collectionId           String    @unique
  estimatedValueMinor    Int
  previousValueMinor     Int
  sevenDayValueMinor     Int
  thirtyDayValueMinor    Int
  collectionHealthScore  Int
  cardsOwned             Int
  setsOwned              Int
  favouriteGame          String
  wishlistOverlapCount   Int
  deckCompletionPercent  Int
  recentGrowthMinor      Int
  heatMap                Json
  recentActivity         Json
  lastUpdatedAt          DateTime
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  collection             Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([collectionHealthScore, lastUpdatedAt])
  @@index([estimatedValueMinor, lastUpdatedAt])
}

model CollectionItem {
  id               String                @id @default(cuid())
  collectionId     String
  productId        String
  ownedQuantity    Int                   @default(1)
  printVariant     CollectionPrintVariant @default(REGULAR)
  condition        ProductCondition      @default(NEAR_MINT)
  foil             Boolean               @default(false)
  language         String                @default("EN")
  notes            String?
  dateAcquired     DateTime?
  purchasePriceMinor Int?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  collection       Collection            @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product          Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  watchlistItems   WatchlistItem[]

  @@unique([collectionId, productId, printVariant, condition, foil, language])
  @@index([collectionId, updatedAt])
  @@index([productId, createdAt])
  @@index([collectionId, productId])
}

model Deck {
  id                 String         @id @default(cuid())
  userId             String
  name               String
  slug               String
  game               String
  ruleProfile        String         @default("CUSTOM")
  visibility         DeckVisibility @default(PRIVATE)
  notes              String?
  imageLabel         String
  maxCards           Int            @default(60)
  maxCopiesPerCard   Int            @default(4)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards              DeckCard[]

  @@unique([userId, slug])
  @@index([userId, visibility])
  @@index([game, visibility])
  @@index([game, ruleProfile])
  @@index([createdAt])
}

model DeckCard {
  id            String   @id @default(cuid())
  deckId        String
  productId     String
  quantity      Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deck          Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([deckId, productId])
  @@index([deckId, updatedAt])
  @@index([productId, createdAt])
}
