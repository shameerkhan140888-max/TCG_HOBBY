{
  "name": "tcg-hobby",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "predev": "node ./scripts/clean-dev.mjs",
    "dev": "npm run db:generate && turbo run dev --filter=@tcg-hobby/storefront --filter=@tcg-hobby/admin --filter=@tcg-hobby/api",
    "dev:all": "npm run db:generate && turbo run dev",
    "dev:mobile": "npm run dev -w @tcg-hobby/mobile",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "typecheck": "turbo run typecheck",
    "db:generate": "npm run db:generate -w @tcg-hobby/database",
    "db:migrate": "npm run db:migrate -w @tcg-hobby/database",
    "db:seed": "npm run db:seed -w @tcg-hobby/database",
    "db:status": "npm run db:status -w @tcg-hobby/database",
    "db:verify": "npm run db:verify -w @tcg-hobby/database",
    "product:validate": "tsx scripts/product-import.ts validate",
    "product:dry-run": "tsx scripts/product-import.ts dry-run",
    "product:import": "tsx scripts/product-import.ts import",
    "product:import:all": "tsx scripts/product-import.ts import-all",
    "admin:promote": "tsx scripts/admin-promote.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml,css}\""
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "prettier": "^3.3.3",
    "turbo": "^2.5.4",
    "typescript": "~5.8.3"
  }
}
