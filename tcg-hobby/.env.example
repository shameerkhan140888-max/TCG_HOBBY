# Copy this file to .env.local and replace placeholder values.
# Database commands intentionally do not load .env.example.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# storefront | coming-soon
TCG_HOBBY_STOREFRONT_MODE="storefront"

# Resend signup confirmation email
RESEND_API_KEY=""
SIGNUP_EMAIL_FROM="TCG Hobby <no-reply@tcg-hobby.co.uk>"
SIGNUP_EMAIL_REPLY_TO="info@tcg-hobby.co.uk"

# Account ownership verification and password recovery email
AUTH_EMAIL_FROM="TCG Hobby <no-reply@tcg-hobby.co.uk>"
AUTH_EMAIL_REPLY_TO="support@tcg-hobby.co.uk"

# Public origin of the separately deployed Admin application
NEXT_PUBLIC_ADMIN_URL="https://admin.tcg-hobby.co.uk"

# Meta Pixel and Conversions API
NEXT_PUBLIC_META_PIXEL_ID=""
META_CONVERSIONS_API_ACCESS_TOKEN=""
META_CONVERSIONS_API_TEST_EVENT_CODE=""
META_CONVERSIONS_API_ENABLED="false"

# Managed product media (Cloudflare R2, server-side except the public asset URL)
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_BASE_URL=""

# Assisted Admin product content (server-side only)
OPENAI_API_KEY=""
OPENAI_CONTENT_MODEL="gpt-5-mini"
